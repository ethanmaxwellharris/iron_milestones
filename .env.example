# Supabase — copy this file to .env.local and fill in your values.
# Create a project at https://supabase.com, then copy these from
# Project Settings → API. Without these the app runs in "Forge Offline" mode
# (all data stored in the browser's localStorage — great for trying it out).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — ONLY needed for the achievement seed script
# (scripts/seed-achievements.ts). Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
